ADAPTIVE_AUDIO_PLAYER_SESSION_SECRET=replace-with-a-long-random-secret
ADAPTIVE_AUDIO_PLAYER_DB_PATH=./data/adaptive-audio-player.sqlite
ADAPTIVE_AUDIO_PLAYER_DATA_ROOT=./data

# Optional: enable real TTS generation instead of mock audio.
OPENAI_API_KEY=

# Optional: tune local worker behavior during development.
ADAPTIVE_AUDIO_PLAYER_WORKER_POLL_MS=150
ADAPTIVE_AUDIO_PLAYER_SAMPLE_JOB_DURATION_MS=350
ADAPTIVE_AUDIO_PLAYER_FULL_BOOK_JOB_DURATION_MS=550
