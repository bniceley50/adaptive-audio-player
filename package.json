{
  "name": "adaptive-audio-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:app": "next dev --hostname 127.0.0.1 --port 3100",
    "dev:all": "node scripts/dev-with-worker.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "rm -rf .next && next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "env -u NO_COLOR playwright test",
    "worker": "node scripts/job-worker.mjs",
    "gate": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "flatted": "3.4.1",
      "undici": "7.24.1"
    }
  }
}
